{
    "system_name": "SATURDAY-PMV-UNIT-01",
    "version": "1.0.0",
    "security": {
        "auto_lock_timeout": 300,
        "encryption_algorithm": "Fernet/AES-128",
        "kdf_iterations": 100000
    },
    "paths": {
        "vault": "./vault",
        "blackbox": "./blackbox",
        "sync_staging": "./staging"
    },
    "sync": {
        "p2p_enabled": true,
        "backend": "syncthing"
    }
}
