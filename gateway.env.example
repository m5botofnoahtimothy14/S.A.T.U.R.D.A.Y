FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT=
AEGIS_NODE_ID=aegis-node-1
AEGIS_DASHBOARD_ORIGINS=https://your-project-id.web.app
AEGIS_API_HOST=127.0.0.1
AEGIS_API_PORT=8443
AEGIS_SSL_CERT_FILE=certs/gateway-cert.pem
AEGIS_SSL_KEY_FILE=certs/gateway-key.pem
AEGIS_MAX_LINEAR_SPEED=0.8
AEGIS_MAX_ANGULAR_SPEED=1.2
AEGIS_MAX_TORQUE=60
AEGIS_MAX_COMMAND_DURATION=5
AEGIS_MIN_OBSTACLE_DISTANCE=0.50
AEGIS_COMMAND_RATE_HZ=20
AEGIS_TELEMETRY_INTERVAL_SECONDS=2
AEGIS_CORE_CONTROL_URL=http://127.0.0.1:8000
AEGIS_CORE_WAKE_TIMEOUT_SECONDS=10
AEGIS_CORE_VERIFY_TLS=false
